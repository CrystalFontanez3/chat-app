Room.js const express = require("express");
const Room = require("../models/Room");
const Message = require("../models/Message");
const auth = require("../middleware/auth");

const router = express.Router();

router.get("/", auth, async (req, res) => {
  const rooms = await Room.find();
  res.json(rooms);
});

router.get("/:roomId/messages", auth, async (req, res) => {
  const messages = await Message.find({ room: req.params.roomId })
    .populate("sender", "username")
    .sort({ timestamp: 1 });

  res.json(messages);
});
server.jsconst express = require("express");
const http = require("http");
const cors = require("cors");
const socketio = require("socket.io");
const connectDB = require("./db");
const authMiddleware = require("./middleware/auth");

const User = require("./models/User");
const Message = require("./models/Message");

const authRoutes = require("./routes/auth");
const userRoutes = require("./routes/users");
const roomRoutes = require("./routes/rooms");

require("dotenv").config();

const app = express();
const server = http.createServer(app);

const io = socketio(server, {
  cors: {
    origin: "*",
    methods: ["GET", "POST"]
  }
});

// Middleware
app.use(cors());
app.use(express.json());

// Routes
app.use("/auth", authRoutes);
app.use("/users", userRoutes);
app.use("/rooms", roomRoutes);

// Connect to MongoDB
connectDB();

// SOCKET.IO
io.use(async (socket, next) => {
  const token = socket.handshake.auth?.token;
  if (!token) return next(new Error("No token"));

  try {
    const decoded = require("jsonwebtoken").verify(token, process.env.JWT_SECRET);
    socket.userId = decoded.id;

    await User.findByIdAndUpdate(socket.userId, { online: true });
    next();
  } catch (err) {
    next(new Error("Invalid token"));
  }
});

io.on("connection", (socket) => {
  console.log("User connected:", socket.userId);

  // Join room
  socket.on("joinRoom", (roomId) => {
    socket.join(roomId);
  });

  // Room message
  socket.on("sendMessage", async ({ roomId, content }) => {
    const msg = await Message.create({
      sender: socket.userId,
      room: roomId,
      content
    });

    io.to(roomId).emit("newMessage", {
      _id: msg._id,
      sender: socket.userId,
      content: msg.content,
      timestamp: msg.timestamp
    });
  });

  // Private DM
  socket.on("sendDM", async ({ recipientId, content }) => {
    const msg = await Message.create({
      sender: socket.userId,
      recipient: recipientId,
      content
    });

    io.to(recipientId).emit("newDM", {
      _id: msg._id,
      sender: socket.userId,
      content: msg.content,
      timestamp: msg.timestamp
    });
  });

  // Typing indicator
  socket.on("typing", ({ roomId }) => {
    socket.to(roomId).emit("typing", socket.userId);
  });

  // Disconnect
  socket.on("disconnect", async () => {
    await User.findByIdAndUpdate(socket.userId, { online: false });
    console.log("User disconnected:", socket.userId);
  });
});

// Start server
const PORT = process.env.PORT || 5000;
